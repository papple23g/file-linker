{
  "name": "file-linker",
  "displayName": "File Linker",
  "description": "Hover and click to instantly open files marked in square brackets using your system's search engine (Everything on Windows, Spotlight on macOS).",
  "version": "1.1.9",
  "publisher": "peterwang",
  "repository": {
    "type": "git",
    "url": "https://github.com/papple23g/file-linker"
  },
  "engines": {
    "vscode": "^1.60.0"
  },
  "categories": [
    "Other"
  ],
  "icon": "logo.png",
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "file-linker.openFile",
        "title": "Open File with Everything"
      }
    ]
  },
  "scripts": {
    "clean": "node -e \"const fs=require('fs'); for (const p of ['out','dist']) fs.rmSync(p,{recursive:true,force:true});\"",
    "vscode:prepublish": "npm run webpack:prod",
    "compile": "webpack --mode none",
    "compile:tsc": "tsc -p .",
    "watch": "webpack --mode none --watch",
    "watch:tsc": "tsc -watch -p .",
    "webpack": "webpack --mode none",
    "webpack:prod": "webpack --mode production",
    "pretest": "npm run clean && npm run compile && npm run compile:tsc && npm run lint",
    "lint": "eslint src --ext ts",
    "test:unit": "mocha --ui tdd --color \"out/test/unit/**/*.test.js\"",
    "test:integration": "node ./out/test/runTest.js",
    "test": "npm run test:unit && npm run test:integration",
    "package": "vsce package"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.10",
    "@types/node": "^16.x.x",
    "@types/vscode": "^1.60.0",
    "@typescript-eslint/eslint-plugin": "^6.x.x",
    "@typescript-eslint/parser": "^6.x.x",
    "@vscode/test-electron": "^2.4.3",
    "eslint": "^8.x.x",
    "glob": "^10.4.5",
    "mocha": "^10.8.2",
    "ts-loader": "^9.5.2",
    "typescript": "^5.x.x",
    "webpack": "^5.99.8",
    "webpack-cli": "^6.0.1"
  },
  "keywords": [],
  "author": "",
  "license": "MIT",
  "type": "commonjs",
  "dependencies": {
    "debug": "^4.4.0",
    "graphemer": "^1.4.0",
    "iconv-lite": "^0.6.3",
    "ignore": "^5.3.2",
    "natural-compare": "^1.4.0",
    "semver": "^7.7.1",
    "ts-api-utils": "^1.4.3"
  }
}
